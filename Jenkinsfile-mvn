pipeline {
       agent {label 'linux_ubuntu'}
       tools {
                 maven 'maven_atm'
        }
        environment {
                      PROJECT_ROOT = "practica-devops"
        }   

    stages{
        stage ('Initialize') {
            steps {
                sh '''
                    echo "PATH = ${PATH}"
                    echo "M2_HOME = ${M2_HOME}"
                ''' 
            }
        }
        stage('Build'){
           steps{
              git branch: 'master', url: 'https://github.com/TadeoT/api-spring.git'
              configFileProvider([configFile(fileId: 'my-maven-settings-dot-xml', variable: 'MAVEN_SETTINGS_XML')]) {
                   sh 'mvn -U --batch-mode -s $MAVEN_SETTINGS_XML clean install -P foo'
               }
           }
       }
    }
        
}
